{
	"tasks": {
		"dev": "deno run --allow-net --allow-env --watch src/main.ts",
		"start": "deno run -P src/main.ts",
		"test": "deno test --allow-all"
	},
	"imports": {
		"@mainframe-api/deno-sqlite": "jsr:@mainframe-api/deno-sqlite@^3.9.1",
		"@std/assert": "jsr:@std/assert@1",
		"@std/http": "jsr:@std/http@^1.0.22",
		"@std/testing": "jsr:@std/testing@^1.0.16"
	},
	"fmt": {
		"useTabs": true,
		"indentWidth": 4
	},
	"lint": {
		"rules": {
			"tags": ["recommended"]
		}
	},
	"permissions": {
		"default": {
			"net": true,
			"env": true
		}
	}
}
