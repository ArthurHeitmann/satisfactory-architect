{
	"tasks": {
		"start": "deno run -P src/main.ts --database-path=db.sqlite",
		"test": "deno test -P=tests"
	},
	"imports": {
		"@mainframe-api/deno-sqlite": "jsr:@mainframe-api/deno-sqlite@^3.9.1",
		"@mongodb-js/zstd": "npm:@mongodb-js/zstd@2.0.0",
		"@std/assert": "jsr:@std/assert@1",
		"@std/cli": "jsr:@std/cli@^1.0.27",
		"@std/http": "jsr:@std/http@^1.0.22",
		"@std/path": "jsr:@std/path@^1.1.3",
		"@std/testing": "jsr:@std/testing@^1.0.16"
	},
	"fmt": {
		"useTabs": true,
		"indentWidth": 4
	},
	"lint": {
		"rules": {
			"tags": ["recommended"]
		}
	},
	"permissions": {
		"default": {
			"net": true,
			"read": {
				"allow": ["db.sqlite", "db.sqlite-journal"]
			},
			"write": {
				"allow": ["db.sqlite", "db.sqlite-journal"]
			},
			"ffi": {
				"allow": ["./node_modules/.deno/@mongodb-js+zstd@2.0.0/node_modules/@mongodb-js/zstd/build/Release/zstd.node"]
			}
		},
		"tests": {
			"net": true,
			"read": true,
			"run": {
				"allow": ["deno"]
			},
			"ffi": {
				"allow": ["./node_modules/.deno/@mongodb-js+zstd@2.0.0/node_modules/@mongodb-js/zstd/build/Release/zstd.node"]
			}
		}
	},
	"nodeModulesDir": "auto",
	"allowScripts": {
		"allow": ["npm:@mongodb-js/zstd@2.0.0"]
	}
}
